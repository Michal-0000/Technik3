<Page x:Class="ZamowieniaPizzzy.PageAdres"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ZamowieniaPizzzy"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="PageAdres">

    <Grid>
        <StackPanel Orientation="Vertical" VerticalAlignment="Top" HorizontalAlignment="Center">
            <Label Content="Adres"/>
            <Label Content="Imię i nazwisko: "/>
            <TextBox Name="ImieNazwisko" Width="200" Height="30"/>
            <Label Content="Ulica i nr"/>
            <TextBox Name="Ulica" Width="200" Height="30"/>
            <Label Content="Kod"/>
            <TextBox Name="Kod" Width="200" Height="30"/>
            <Label Content="Miejscowosc"/>
            <TextBox Name="Miasto" Width="200" Height="30"/>
            <Button Name="Dalej" Content="Dalej" Width="130" Height="30" Margin="10" Click="Dalej_Click"/>
        </StackPanel>
    </Grid>
</Page>
