<Window x:Class="WatkiCwiczenie9.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WatkiCwiczenie9"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <StackPanel Orientation="Vertical" Margin="10">
            <Grid Height="50" VerticalAlignment="Top" Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Label Content="Temperatura:" Margin="10" Grid.Column="0"/>
                <TextBlock Name="txtTemperature" Margin="10" Width="40" Height="20" Text="0 °C" Grid.Column="1"/>
                <Button Name="btnTempStart" Content="Start" Width="50" Height="30" Margin="5" Grid.Column="3" Click="btnTempStart_Click"/>
                <Button Name="btnTempStop" Content="Stop" Width="50" Height="30" Margin="5" Grid.Column="4" Click="btnTempStop_Click"/>
            </Grid>
            <Grid>
                <Grid Height="50" VerticalAlignment="Top" Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Label Content="Pasek postępu: " Grid.Column="0"/>
                    <ProgressBar Name="progressBar" Margin="10" Width="200" Height="20" Maximum="100" Grid.Column="1"/>
                    <Button Name="btnProgressStart" Content="Start" Width="50" Height="30" Margin="5" Grid.Column="3" Click="btnProgressStart_Click"/>
                    <Button Name="btnProgressStop" Content="Stop" Width="50" Height="30" Margin="5" Grid.Column="4" Click="btnProgressStop_Click"/>
                </Grid>
            </Grid>

            <Grid>
                <Grid Height="50" VerticalAlignment="Center" Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Label Content="Pliki: " Grid.Column="0"/>
                    <TextBlock Name="txtFilesStats" Text="Utworzone: 0, Usunięte: 0" Grid.Column="1"/>
                    <Button Name="btnFilesStart" Content="Start" Width="50" Height="30" Margin="5" Grid.Column="3" Click="btnFilesStart_Click"/>
                    <Button Name="btnFilesStop" Content="Stop" Width="50" Height="30" Margin="5" Grid.Column="4" Click="btnFilesStop_Click"/>
                </Grid>
            </Grid>
            <TextBlock Name="txtFilesNames" Width="400" Height="200" Margin="10" Background="LightGray"/>
        </StackPanel>
    </Grid>
</Window>
